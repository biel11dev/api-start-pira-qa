generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Balance {
  id               Int       @id @default(autoincrement())
  date             String
  balance          Float
  balancefim       Float?
  lucro            Float?
  cartao           Float?
  dinheiro         Float?
  cartaofimcaixa   Float?
  dinheirofimcaixa Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime?
}

model Client {
  id        Int        @id @default(autoincrement())
  name      String
  totalDebt Float
  createdAt DateTime   @default(now())
  updatedAt DateTime @updatedAt
  Payment   Payment[]
  Purchase  Purchase[]
  Comanda   PdvComanda[]
}

model DailyReading {
  id        Int      @id @default(autoincrement())
  date      String
  value     Float
  machineId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Machine   Machine  @relation(fields: [machineId], references: [id])
}

model Despesa {
  id           Int      @id @default(autoincrement())
  nomeDespesa  String?
  valorDespesa Float?
  descDespesa  String?
  date         DateTime
  DespesaFixa  Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime? @updatedAt
}

model Machine {
  id           Int            @id @default(autoincrement())
  name         String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime? @updatedAt
  DailyReading DailyReading[]
}

model Payment {
  id        Int      @id @default(autoincrement())
  amount    Float
  date      String
  clientId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  Client    Client   @relation(fields: [clientId], references: [id])
}

model Category {
  id             Int         @id @default(autoincrement())
  name           String
  parentId       Int?        // Campo para subcategoria
  parent         Category?   @relation("CategorySubcategories", fields: [parentId], references: [id])
  subcategories  Category[]  @relation("CategorySubcategories")
  products       Product[]
  prod_estoq     Estoque[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  quantity  Int
  unit      String
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  value     Float
  valuecusto Float
  estoqueItems Estoque[]
}

model Estoque {
  id          Int      @id @default(autoincrement())
  productId   Int      // Vinculado ao catálogo de produtos
  product     Product  @relation(fields: [productId], references: [id])
  name        String
  quantity    Int
  unit        String
  categoria_Id Int?
  category   Category? @relation(fields: [categoria_Id], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime? @updatedAt
  value      Float
  valuecusto Float
  stockMovements StockMovement[]
  saleItems      SaleItem[]

  @@index([productId])
}

model Purchase {
  id        Int      @id @default(autoincrement())
  product   String
  quantity  Int
  total     Float
  date      String
  clientId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Client    Client   @relation(fields: [clientId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String?
  caixa     Boolean?
  produtos  Boolean?
  maquinas  Boolean?
  fiado     Boolean?
  despesas  Boolean?
  ponto     Boolean?
  acessos   Boolean?
  base_produto Boolean?
  pdv Boolean?
  pessoal Boolean?
  auditoria Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id          Int          @id @default(autoincrement())
  name        String       // Nome do funcionário
  position    String?      // Cargo do funcionário (opcional)
  carga       Int          @default(0) // Mantido para compatibilidade
  valorHora   Float        @default(0) // Valor por hora do funcionário
  metaHoras   Float?       // Meta de horas semanais para bonificação (ATUAL)
  bonificacao Float?       // Valor da bonificação semanal
  contato     String?      // Contato do funcionário
  dataEntrada DateTime?    // Data de entrada do funcionário
  ativo       Boolean      @default(true) // Status do funcionário
  createdAt   DateTime     @default(now()) // Data de criação do registro
  points      DailyPoint[] // Relacionamento com os pontos diários
  metaHistory EmployeeMetaHistory[] // Histórico de metas
  weeklyMetas EmployeeWeeklyMeta[] // Metas por semana
}

model EmployeeMetaHistory {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  valorHora   Float    // Valor por hora
  metaHoras   Float    // Meta de horas semanais
  bonificacao Float    // Valor da bonificação
  validFrom   DateTime // Data de início da vigência (primeiro dia do mês)
  validUntil  DateTime? // Data de fim da vigência (null = atual)
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@index([employeeId, validFrom])
}

model DailyPoint {
  id         Int      @id @default(autoincrement())
  date       DateTime? // Data do ponto
  entry      DateTime? // Horário de entrada
  exit       DateTime? // Horário de saída
  gateOpen   DateTime? // Horário de abertura do portão (opcional)
  falta      Boolean?  // Falta ou não
  employeeId Int      // Relacionamento com o funcionário
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeWeeklyMeta {
  id          Int      @id @default(autoincrement())
  employeeId  Int      // ID do funcionário
  year        Int      // Ano da semana
  month       Int      // Mês da semana
  weekStart   DateTime // Data de início da semana (terça-feira)
  weekEnd     DateTime // Data de fim da semana (domingo)
  metaHoras   Float    // Meta de horas semanais
  bonificacao Float    // Valor da bonificação semanal
  valorHora   Float    // Valor por hora (snapshot do momento)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, weekStart])
  @@index([employeeId, year, month])
}

model CadDespesa {
  id         Int      @id @default(autoincrement())
  nomeDespesa String?
  createdAt DateTime     @default(now()) // Data de criação do registro

}

model MachineWeekValue {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  week      Int
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id             Int        @id @default(autoincrement())
  total          Float
  paymentMethod  String
  customerName   String
  amountReceived Float
  change         Float
  date           DateTime
  items          SaleItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      Int
  estoqueId   Int
  productName String
  quantity    Float
  unitPrice   Float
  total       Float
  sale        Sale     @relation(fields: [saleId], references: [id])
  estoque     Estoque  @relation(fields: [estoqueId], references: [id])
}

model StockMovement {
  id            Int      @id @default(autoincrement())
  estoqueId     Int
  estoque       Estoque  @relation(fields: [estoqueId], references: [id])
  type          String   // SALE, ADJUSTMENT, ENTRY, RETURN
  quantity      Float    // quantidade movimentada (positivo = entrada, negativo = saída)
  previousStock Int      // estoque antes da movimentação
  newStock      Int      // estoque depois da movimentação
  description   String?  // descrição/motivo da movimentação
  referenceId   Int?     // ID da venda ou outra referência
  referenceType String?  // "Sale", "Manual", etc.
  createdAt     DateTime @default(now())

  @@index([estoqueId])
  @@index([type])
  @@index([createdAt])
}

model UnitEquivalence {
  id        Int      @id @default(autoincrement())
  unitName  String   @unique
  value     Float    // Quantas unidades representa (ex: 1 Maço = 20 Unidades)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DespPessoal{
  id           Int      @id @default(autoincrement())
  nomeDespesa  String
  valorDespesa Float?
  descDespesa  String?
  date         DateTime
  DespesaFixa  Boolean
  tipoMovimento String  @default("GASTO") // "GASTO" ou "GANHO"
  categoriaId  Int?
  categoria    CatDespPessoal? @relation(fields: [categoriaId], references: [id])
  valeRelacionadoId Int? // ID do registro relacionado (GASTO <-> GANHO/VALE)
  isVale       Boolean  @default(false) // Indica se é um vale
  createdAt    DateTime @default(now())
  updatedAt    DateTime? @updatedAt
}

model CatDespPessoal{
  id           Int      @id @default(autoincrement())
  nomeCategoria  String?
  createdAt    DateTime @default(now())
  DespPessoal DespPessoal[]
}

model Auditoria {
  id          Int      @id @default(autoincrement())
  modulo      String   // Nome do módulo (caixa, pdv, fiado, etc.)
  acao        String   // Método HTTP: POST, PUT, DELETE, GET
  descricao   String?  // Descrição da ação realizada
  rota        String   // Rota da API chamada
  userId      Int?     // ID do usuário que realizou a ação
  userName    String?  // Nome do usuário para consulta rápida
  ip          String?  // IP do requisitante
  payload     String?  // JSON com dados enviados (body resumido)
  createdAt   DateTime @default(now())

  @@index([modulo])
  @@index([userId])
  @@index([createdAt])
  @@index([acao])
}

model AuditoriaConfig {
  id          Int      @id @default(autoincrement())
  modulo      String   @unique // Nome do módulo
  ativo       Boolean  @default(true) // Se o módulo deve ser auditado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PdvCaixaMovimento {
  id          Int      @id @default(autoincrement())
  tipo        String   // "ADD", "SANGRIA", etc.
  valor       Float
  origens     PdvCaixaOrigem[]
  userId      Int?
  userName    String?
  observacao  String?
  createdAt   DateTime @default(now())

  @@index([tipo])
  @@index([createdAt])
}

model PdvCaixaOrigem {
  id            Int      @id @default(autoincrement())
  movimentoId   Int
  movimento     PdvCaixaMovimento @relation(fields: [movimentoId], references: [id], onDelete: Cascade)
  nome          String   // Nome da origem (ex: "Cofre", "Banco", "Pessoal")
  valor         Float
  createdAt     DateTime @default(now())

  @@index([movimentoId])
}

model PdvOrigemConfig {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PdvPremio {
  id          Int      @id @default(autoincrement())
  imagem1     String   @db.Text // Base64 - prova do ganho no caça-níquel
  imagem2     String   @db.Text // Base64 - prova da baixa do valor no jogo
  valor       Float
  observacao  String?
  userId      Int?
  userName    String?
  origens     PdvPremioOrigem[]
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model PdvPremioOrigem {
  id          Int      @id @default(autoincrement())
  premioId    Int
  premio      PdvPremio @relation(fields: [premioId], references: [id], onDelete: Cascade)
  nome        String
  valor       Float
  createdAt   DateTime @default(now())

  @@index([premioId])
}

model PdvCupom {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique
  tipo            String    // "PERCENTUAL" ou "FIXO"
  valor           Float     // Percentual (ex: 10) ou valor fixo (ex: 5.00)
  descricao       String?
  validoAte       DateTime?
  limiteUso       Int?      // null = ilimitado
  vezesUsado      Int       @default(0)
  ativo           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([codigo])
  @@index([ativo])
}

model PdvTaxaMaquina {
  id          Int      @id @default(autoincrement())
  nome        String   // Ex: "Taxa cartão crédito", "Taxa PIX"
  tipo        String   // "PERCENTUAL" ou "FIXO"
  valor       Float
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PdvConfigVenda {
  id              Int      @id @default(autoincrement())
  chave           String   @unique  // Ex: "limite_comanda", "max_comandas_abertas"
  valor           String   // Armazena o valor como string (flex)
  descricao       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PdvFormaPagamento {
  id        Int      @id @default(autoincrement())
  nome      String   @unique  // Ex: "Dinheiro", "Cartão", "PIX", "Fiado"
  valor     String   // valor interno usado no sistema (ex: "dinheiro", "cartao", "pix", "fiado")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PdvComanda {
  id            Int               @id @default(autoincrement())
  clientId      Int
  client        Client            @relation(fields: [clientId], references: [id])
  saleId        Int?              // Venda que originou a comanda
  total         Float
  status        String            @default("ABERTA") // "ABERTA", "PAGA", "FIADO"
  paymentMethod String?           // Preenchido quando paga
  items         PdvComandaItem[]
  createdAt     DateTime          @default(now())
  paidAt        DateTime?
  updatedAt     DateTime          @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model PdvComandaItem {
  id          Int        @id @default(autoincrement())
  comandaId   Int
  comanda     PdvComanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  productName String
  quantity    Float
  unitPrice   Float
  total       Float
  estoqueId   Int?
  createdAt   DateTime   @default(now())

  @@index([comandaId])
}